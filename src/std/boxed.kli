fun alloc[T](value : T) -> box[T] = do
    let ptr = allocate[T](1);
    ptr^ = value;
    box_from_raw(ptr)
end

fun dealloc[T](b : box[T]) -> T = do 
    let ptr = box_into_raw(b);
    let value = ptr^;
    deallocate(ptr);
    value
end

fun deref[r,T](x : imm[r] box[T]) -> imm[r] T = panic[imm[r] T]

fun derefMut[r,T](x : mut[r] box[T]) -> mut[r] T = panic[mut[r] T]