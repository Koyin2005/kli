import std.arrays.new as array_new
import std.arrays.ArrayList
import std.optional.Option
import std.optional.take

import std.arrays

type Result[T,E] = | Ok(T) | Err(E)

type Entry[K,V] = {
    hash : int,
    data : Pair[K,V]
}

type HashMap[K,V] = {
    buckets : ArrayList[Entry[K,V]]
}

fun hash[r,K](key : imm[r] K) -> int;
fun equal[r,K](first : imm[r] K, second : imm[r] K) -> bool;

fun new[K,V]() -> HashMap[K,V] = do
    HashMap {
        buckets = arrays.new()
    }
end