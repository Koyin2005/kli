fun replace[r,T](m : mut[r] T, f : fun(T) => T) -> mut[r] T = do
    let p = ref_into_raw_mut(m);
    let tmp = ptr_read(p);
    ptr_write(p,f(tmp));
    ref_from_raw_mut(p)
end

fun swap[r,T](m : mut[r] T, value : T) -> T = do
    let p = ref_into_raw_mut(m);
    let tmp = ptr_read(p);
    ptr_write(p,value);
    tmp
end