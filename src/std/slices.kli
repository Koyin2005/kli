import std.phantom
import builtins.transmute
import builtins.offset
import std.optional.Option

@lang_item("slice")
@copy
@opaque
type Slice[region r,T] = {
    ptr : ptr[T],
    len : int
}


@unsafe
fun from_raw_parts[region r,T](ptr : ptr[T], len : int) -> Slice[r,T] = 
    Slice{
        ptr = ptr,
        len = len
    }

fun from_ref[region r,T]( ref_value : imm[r] T) -> Slice[r,T] = 
    from_raw_parts(transmute(ref_value),1)

fun len[region r,T](slice : Slice[r,T]) -> int = 
    slice.len

fun get[region r,T](slice : Slice[r,T], index: int) -> Option[imm[r] T] = 
    case index > 0 and index < slice.len of
    | true -> Option.Some(transmute(offset(slice.ptr,index)))
    | false -> Option.None
    end

fun index_out_bounds() -> never = 
    panic

fun expect[region r,T](slice : Slice[r,T], index: int) -> imm[r] T = 
    case index > 0 and index < slice.len of
    | true -> transmute(offset(slice.ptr,index))
    | false -> index_out_bounds()
    end

fun split_at[region r,T](slice : Slice[r,T], index : int) -> Option[(Slice[r,T],Slice[r,T])] = do
    case index < 0  of 
    | true -> return Option.None
    | false -> ()
    end;
    
    case index > slice.len  of 
    | true -> return Option.None
    | false -> ()
    end;

    let left_ptr = slice.ptr;
    let left_len = index;
    let left = from_raw_parts(left_ptr,left_len);

    let right_ptr = offset(slice.ptr,index);
    let right_len = slice.len - index;
    let right = from_raw_parts(right_ptr,right_len);
    Option.Some((left,right))
end